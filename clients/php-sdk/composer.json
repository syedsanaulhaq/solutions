{
    "name": "hostingocean/sdk",
    "description": "Official PHP SDK for the HostingOcean API",
    "version": "0.1.0",
    "type": "library",
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "guzzlehttp/psr7": "^2.7"
    },
    "autoload": {
        "psr-4": {
            "HostingOcean\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HostingOcean\\Tests\\": "tests/"
        }
    }
}
