NEXT_PUBLIC_API_URL=https://api.hostingocean.com
NEXT_PUBLIC_SITE_URL=https://solutions.hostingocean.com

# AI Chatbot — choose one provider: openai | groq | deepseek
AI_PROVIDER=openai
AI_API_KEY=your_key_here
# AI_MODEL=gpt-4o-mini   # optional override

# Quote lead email notifications (all five required to enable; omit to skip silently)
SMTP_HOST=solutions.hostingocean.co.uk
SMTP_PORT=465
SMTP_USER=noreply@solutions.hostingocean.co.uk
SMTP_PASS=your_email_password
LEAD_NOTIFY_EMAIL=leads@solutions.hostingocean.co.uk

# Admin dashboard password — required to access /admin/leads
ADMIN_DASH_PASSWORD=your_admin_password_here
