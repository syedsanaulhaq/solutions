# ──────────────────────────────────────────────
#  HostingOcean.net (Pakistan) — Environment Variables
# ──────────────────────────────────────────────

# Site
NEXT_PUBLIC_SITE_URL=https://www.hostingocean.net

# Contact Form (Nodemailer)
SMTP_HOST=mail.hostingocean.net
SMTP_PORT=587
SMTP_USER=info@hostingocean.net
SMTP_PASS=
CONTACT_EMAIL=info@hostingocean.net

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=hostingocean.net
NEXT_PUBLIC_CLARITY_ID=

# AI Chatbot
# Provider: openai | groq | deepseek  (default: openai)
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini
